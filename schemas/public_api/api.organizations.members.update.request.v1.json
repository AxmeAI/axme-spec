{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axme.dev/schemas/public_api/api.organizations.members.update.request.v1.json",
  "title": "ApiOrganizationsMembersUpdateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "org_id",
    "member_id"
  ],
  "properties": {
    "org_id": {
      "type": "string",
      "format": "uuid"
    },
    "member_id": {
      "type": "string",
      "format": "uuid"
    },
    "workspace_id": {
      "type": "string",
      "format": "uuid"
    },
    "role": {
      "type": "string",
      "enum": [
        "org_owner",
        "org_admin",
        "workspace_admin",
        "member",
        "billing_viewer",
        "security_auditor"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "invited",
        "suspended",
        "removed"
      ]
    }
  }
}
