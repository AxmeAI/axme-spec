{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axme.dev/schemas/public_api/api.organizations.workspaces.update.request.v1.json",
  "title": "ApiOrganizationsWorkspacesUpdateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "org_id",
    "workspace_id"
  ],
  "properties": {
    "org_id": {
      "type": "string",
      "format": "uuid"
    },
    "workspace_id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "archived"
      ]
    },
    "region": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    }
  }
}
